---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const imageModules = import.meta.glob<{ default: ImageMetadata }>('../assets/mugs/*.{jpg,jpeg,png,webp,avif}', { eager: true });
const mugs = Object.values(imageModules).map(m => m.default);
---

<Layout title="Mugs — Tyler Hilker" description="Tyler Hilker's diner mug collection">
  <main>
    <header>
      <a href="/" class="back muted small">← Tyler Hilker</a>
      <h1>Mugs</h1>
      <p class="muted">Diner-style mugs. The right size, the right weight, the right feel.</p>
    </header>

    <hr />

    {mugs.length === 0 ? (
      <p class="muted small">Photos coming soon.</p>
    ) : (
      <div class="mug-grid">
        {mugs.map((src) => (
          <div class="mug">
            <Image src={src} alt="Mug" width={400} height={400} loading="lazy" />
          </div>
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  main {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back:hover {
    color: var(--color-text);
  }

  .mug-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .mug {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .mug img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transform: scale(1);
    transition: filter 0.2s ease, transform 0.2s ease;
  }

  .mug img:hover {
    filter: grayscale(0%);
    transform: scale(1.06);
  }

  @media (max-width: 480px) {
    .mug-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
